rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    
    function isValidBot() {
      return request.resource.data.keys().hasOnly(['uid', 'botId', 'name', 'username', 'createdAt', 'token', 'isActive', 'description', 'shortDescription']) &&
             request.resource.data.uid is string &&
             request.resource.data.botId is string &&
             request.resource.data.name is string &&
             request.resource.data.username is string &&
             request.resource.data.createdAt is string &&
             request.resource.data.token is string;
    }
    
    function isValidBotRules() {
      return hasOnlyAllowedFields(['uid', 'rules']) &&
             request.resource.data.uid is string &&
             request.resource.data.rules is list &&
             request.resource.data.rules.size() <= 100;
    }

    match /bots/{botId} {
      allow read: if true;
      allow create: if isValidBot();
      allow update: if isValidBot();
      allow delete: if true;
      
      match /users/{userId} {
        allow read: if true;
        allow write: if true; // Webhook needs to write here without auth
      }
    }

    match /bot_rules/{botId} {
      allow read: if true;
      allow create: if isValidBotRules();
      allow update: if isValidBotRules();
      allow delete: if true;
    }
  }
}
