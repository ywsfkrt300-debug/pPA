rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    
    function isValidBot() {
      return hasOnlyAllowedFields(['uid', 'botId', 'name', 'username', 'createdAt']) &&
             request.resource.data.uid is string &&
             request.resource.data.botId is string &&
             request.resource.data.name is string &&
             request.resource.data.username is string &&
             request.resource.data.createdAt is string;
    }
    
    function isValidBotRules() {
      return hasOnlyAllowedFields(['uid', 'rules']) &&
             request.resource.data.uid is string &&
             request.resource.data.rules is list &&
             request.resource.data.rules.size() <= 100;
    }

    match /bots/{botId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidBot();
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid && isValidBot();
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /bot_rules/{botId} {
      // Server needs to read rules unauthenticated to process webhooks
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidBotRules();
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid && isValidBotRules();
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
