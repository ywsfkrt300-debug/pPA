{
  "entities": {
    "Bot": {
      "title": "Bot",
      "description": "A Telegram bot configuration",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "botId": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "token": { "type": "string" },
        "isActive": { "type": "boolean" },
        "description": { "type": "string" },
        "shortDescription": { "type": "string" },
        "maxMessages": { "type": "number" },
        "password": { "type": "string" }
      },
      "required": ["uid", "botId", "name", "username", "createdAt", "token"]
    },
    "BotUser": {
      "title": "BotUser",
      "description": "A user who interacted with the bot",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "username": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "messageCount": { "type": "number" },
        "isBanned": { "type": "boolean" },
        "isUnlocked": { "type": "boolean" }
      },
      "required": ["id"]
    },
    "BotRules": {
      "title": "BotRules",
      "description": "The auto-reply rules for a bot",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user ID of the owner"
        },
        "rules": {
          "type": "array",
          "description": "List of rules",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "triggerType": { "type": "string", "enum": ["command", "text_match", "any"] },
              "triggerValue": { "type": "string" },
              "responseType": { "type": "string", "enum": ["text"] },
              "responseValue": { "type": "string" }
            },
            "required": ["id", "triggerType", "responseType", "responseValue"]
          }
        }
      },
      "required": ["uid", "rules"]
    }
  },
  "firestore": {
    "bots/{botId}": {
      "schema": "Bot",
      "description": "Stores bot configurations"
    },
    "bot_rules/{botId}": {
      "schema": "BotRules",
      "description": "Stores auto-reply rules for bots"
    }
  }
}
